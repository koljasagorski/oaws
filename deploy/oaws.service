[Unit]
Description=OAWS Tracker Web (FastAPI/uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__APP_DIR__
ExecStart=__APP_DIR__/.venv/bin/uvicorn server.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3
# Secrets liegen in __APP_DIR__/.env (von der App selbst gelesen, chmod 600)

[Install]
WantedBy=multi-user.target
