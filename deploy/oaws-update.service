[Unit]
Description=OAWS taeglicher Pipeline-Lauf (Episoden -> Build)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=__USER__
WorkingDirectory=__APP_DIR__
ExecStart=__APP_DIR__/.venv/bin/python pipeline/run.py
# Lange Laeufe (Vollarchiv) erlauben
TimeoutStartSec=7200
